# Copy this file to gcp-vm/.env.secrets and keep it out of git.

# DuckDNS token used by vm-ctl / Cloud Run.
DUCKDNS_TOKEN=

# Preferred: path to an rclone OAuth token JSON for the Google account that owns
# the Drive folder referenced by GDRIVE_FOLDER_ID. The deploy script uploads this
# JSON into Secret Manager and the VM reads it during backup/restore.
GDRIVE_OAUTH_TOKEN_FILE=

# Optional fallback: path to a Google service account JSON file. This is less
# reliable for consumer Google Drive accounts because service accounts do not get
# normal Drive storage quota.
GDRIVE_SERVICE_ACCOUNT_JSON_FILE=

# Optional: set USER_PASSWORD explicitly instead of using the placeholder.
USER_PASSWORD=
