# Copy this file to gcp-vm/.env.secrets and keep it out of git.

# DuckDNS token used by vm-ctl / Cloud Run.
DUCKDNS_TOKEN=

# Path to a Google service account JSON file that has access to the shared
# Google Drive folder referenced by GDRIVE_FOLDER_ID.
# The deploy script uploads this JSON into Secret Manager and the VM reads it
# from Secret Manager during backup/restore.
GDRIVE_SERVICE_ACCOUNT_JSON_FILE=

# Optional: set USER_PASSWORD explicitly instead of using the placeholder.
USER_PASSWORD=
