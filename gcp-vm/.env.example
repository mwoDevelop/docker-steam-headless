# Copy this file to gcp-vm/.env and fill required values.
# Copy gcp-vm/.env.secrets.example to gcp-vm/.env.secrets for passwords / tokens.
# Used by: gcp-vm/deploy-gce.sh and gcp-vm/vm-ctl.sh
# Both local files stay gitignored and should not be committed.

# Required
GCP_PROJECT=

# Core VM settings
GCP_ZONE=europe-central2-b
GCE_NAME=steam-gpu

# Deploy (compute) settings
MACHINE_TYPE=n1-standard-4
GPU_TYPE=nvidia-tesla-t4
GPU_COUNT=1
BOOT_DISK_SIZE=120GB
BOOT_DISK_TYPE=pd-ssd
TAGS=steam-headless

# Default source range used by deploy for initial firewall rules.
# Prefer your current IP/32 instead of 0.0.0.0/0 on a public VM.
ALLOW_CIDR=0.0.0.0/0

# Firewall rule names/tags/network used by vm-ctl
FW_RULE_WEB=allow-steam-headless-web
FW_RULE_SUN=allow-sunshine
FW_TAGS=steam-headless
FW_NET=default

# Port sets used by vm-ctl allow/open
ALLOW_WEB_PORTS=tcp:22,tcp:8083
ALLOW_SUN_PORTS=tcp:47984,tcp:47989,tcp:47990,tcp:48010,tcp:27036-27037,udp:47998,udp:47999,udp:48000,udp:48002,udp:27031-27036

# Optional DuckDNS update on "vm-ctl.sh up"
# Comma-separated names, with or without .duckdns.org suffix.
# Keep the matching token in gcp-vm/.env.secrets.
DUCKDNS_DOMAINS=

# Steam Headless app config propagated to the VM startup script
# Keep real credentials only in local gcp-vm/.env.secrets
NAME=SteamHeadless
TZ=Europe/Warsaw
USER_LOCALES="en_US.UTF-8 UTF-8"
DISPLAY=:5
SHM_SIZE=4GB
HOME_DIR=/opt/container-data/steam-headless/home
SHARED_SOCKETS_DIR=/opt/container-data/steam-headless/sockets
GAMES_DIR=/mnt/games
PUID=1000
PGID=1000
UMASK=000
MODE=primary
WEB_UI_MODE=vnc
ENABLE_VNC_AUDIO=true
PORT_NOVNC_WEB=8083
NEKO_NAT1TO1=
ENABLE_STEAM=true
STEAM_ARGS=-silent
ENABLE_SUNSHINE=true
# Sunshine Web UI login is fixed to admin.
# The password is rotated to a random runtime value when the VM starts from the GUI.
SUNSHINE_USER=admin
ENABLE_EVDEV_INPUTS=true
FORCE_X11_DUMMY_CONFIG=true
DISPLAY_SIZEW=1920
DISPLAY_SIZEH=1080
DISPLAY_REFRESH=60
DISPLAY_CDEPTH=24
NVIDIA_DRIVER_CAPABILITIES=all
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_VERSION=
